{
    "info": {
        "_postman_id": "e8a9d1b6-0b3b-4b1a-9c1a-1a2b3c4d5e6f",
        "name": "Event Registration API",
        "description": "Postman collection for testing the new Event Registration and My Events API endpoints.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "Member Auth",
            "item": [
                {
                    "name": "Member Login",
                    "request": {
                        "method": "POST",
                        "header": [],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"email\": \"member@example.com\",\n    \"password\": \"memberPassword\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/member/login",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "member",
                                "login"
                            ]
                        }
                    },
                    "response": []
                }
            ]
        },
        {
            "name": "Event Registration",
            "item": [
                {
                    "name": "Register for Event (Initiate)",
                    "request": {
                        "method": "POST",
                        "header": [],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"additionalInfo\": \"Any extra data for registration if needed\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/member/events/register/:eventId",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "member",
                                "events",
                                "register",
                                ":eventId"
                            ],
                            "variable": [
                                {
                                    "key": "eventId",
                                    "value": "ENTER_EVENT_ID_HERE"
                                }
                            ]
                        }
                    },
                    "response": []
                },
                {
                    "name": "Verify Event Payment",
                    "request": {
                        "method": "POST",
                        "header": [],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"razorpay_order_id\": \"order_ID_received_from_register_api\",\n    \"razorpay_payment_id\": \"pay_fake_ID_for_testing\",\n    \"razorpay_signature\": \"fake_signature_for_testing\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/member/events/verify-payment",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "member",
                                "events",
                                "verify-payment"
                            ]
                        }
                    },
                    "response": []
                }
            ]
        },
        {
            "name": "My Profile",
            "item": [
                {
                    "name": "My Registered Events",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{baseUrl}}/api/member/events/my-events",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "member",
                                "events",
                                "my-events"
                            ]
                        }
                    },
                    "response": []
                }
            ]
        }
    ],
    "event": [
        {
            "listen": "prerequest",
            "script": {
                "type": "text/javascript",
                "exec": [
                    ""
                ]
            }
        },
        {
            "listen": "test",
            "script": {
                "type": "text/javascript",
                "exec": [
                    ""
                ]
            }
        }
    ],
    "variable": [
        {
            "key": "baseUrl",
            "value": "http://localhost:5000",
            "type": "string"
        }
    ]
}